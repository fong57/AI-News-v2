# LiteNews AI Configuration
# Copy this file to .env and fill in your API keys

# === LangSmith Tracing (Optional but recommended) ===
# Get your API key from https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=litenews-ai
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# === LLM API Keys ===
# Perplexity API Key (get from https://www.perplexity.ai/settings/api)
PPLX_API_KEY=your_perplexity_api_key_here

# DashScope/Qwen API Key (get from https://dashscope.console.aliyun.com/)
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# === Search API Keys ===
# Tavily API Key (get from https://app.tavily.com/)
TAVILY_API_KEY=your_tavily_api_key_here

# === LLM Configuration (Optional - defaults provided) ===
# Primary reasoning LLM: "perplexity" or "qwen"
PRIMARY_LLM=perplexity

# Perplexity model (options: sonar, sonar-pro, sonar-reasoning)
PERPLEXITY_MODEL=sonar

# Qwen model (options: qwen-turbo, qwen-plus, qwen-max, qwen-flash)
QWEN_MODEL=qwen-flash

# === Search Configuration (Optional) ===
# Search depth: basic, advanced, fast, ultra-fast
TAVILY_SEARCH_DEPTH=advanced

# Maximum search results
TAVILY_MAX_RESULTS=5

# Search topic: general, news, finance
TAVILY_TOPIC=news

# === Agent Configuration (Optional) ===
# Maximum tokens for LLM responses
MAX_TOKENS=4096

# Temperature for LLM (0.0 - 1.0)
TEMPERATURE=0.0
