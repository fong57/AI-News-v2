# LiteNews AI Configuration
# Copy this file to .env and fill in your API keys

# === LangSmith Tracing (Optional but recommended) ===
# Get your API key from https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=litenews-ai
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_RESOURCE_URL=https://your-deployment.langchain.run

# === LLM API Keys ===
# Perplexity API Key (get from https://www.perplexity.ai/settings/api)
PPLX_API_KEY=your_perplexity_api_key_here

# DashScope/Qwen API Key (get from https://dashscope.console.aliyun.com/)
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Alibaba Bailian (Model Studio) — OpenAI-compatible key from https://bailian.console.aliyun.com/
# Often the same family of keys as DashScope; use a dedicated key if you prefer.
BAILIAN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_API_KEY=your_bailian_api_key_here

# === Search API Keys ===
# Tavily API Key (get from https://app.tavily.com/)
TAVILY_API_KEY=your_tavily_api_key_here

# === LLM Configuration (Optional - defaults provided) ===
# Primary reasoning LLM: "perplexity", "qwen", or "bailian"
PRIMARY_LLM=perplexity

# Perplexity model (options: sonar, sonar-pro, sonar-reasoning)
PERPLEXITY_MODEL=sonar

# Qwen model (options: qwen-turbo, qwen-plus, qwen-max, qwen-flash)
QWEN_MODEL=qwen-flash

# Bailian compatible-mode model id (see Model Studio console)
BAILIAN_MODEL=qwen3-32b-ft-202603261047-4f57

# === Search Configuration (Optional) ===
# Search depth: basic, advanced, fast, ultra-fast (shared by research, fact-check, write)
TAVILY_SEARCH_DEPTH=advanced

# Max results per Tavily query, per workflow node (1–20)
TAVILY_RESEARCH_MAX_RESULTS=20
TAVILY_FACT_CHECK_MAX_RESULTS=10
TAVILY_WRITE_MAX_RESULTS=5

# Search topic: general, news, finance (shared)
TAVILY_TOPIC=news

# Comma-separated domains to exclude from Tavily (API + never stored in workflow state)
# TAVILY_EXCLUDE_DOMAINS=example-tabloid.com,low-quality.example

# === Agent Configuration (Optional) ===
# Maximum tokens for LLM responses
MAX_TOKENS=4096

# Temperature for LLM (0.0 - 1.0)
TEMPERATURE=0.0
